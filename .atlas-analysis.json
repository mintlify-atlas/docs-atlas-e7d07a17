  "publicApiSurface": [
    "GET /api/v1/hardware - List all assets",
    "POST /api/v1/hardware - Create asset",
    "GET /api/v1/licenses - List all licenses",
    "POST /api/v1/licenses - Create license",
    "GET /api/v1/accessories - List accessories",
    "GET /api/v1/consumables - List consumables",
    "GET /api/v1/components - List components",
    "GET /api/v1/users - List users",
    "GET /api/v1/locations - List locations",
    "POST /api/v1/hardware/{id}/checkout - Check out asset",
    "POST /api/v1/hardware/{id}/checkin - Check in asset",
    "GET /api/v1/manufacturers - List manufacturers",
    "GET /api/v1/suppliers - List suppliers",
    "GET /api/v1/categories - List categories",
    "GET /api/v1/statuslabels - List status labels"
